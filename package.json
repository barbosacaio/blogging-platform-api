{
  "name": "blogging-platform-api",
  "version": "1.0.0",
  "description": "**Portfolio Project** — A RESTful API with CRUD routes for a personal blog. The included core functions include creating posts, updating a post, deleting a post, searching posts by ID, listing all posts, and filtering by keywords.",
  "bugs": {
    "url": "https://github.com/barbosacaio/blogging-platform-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barbosacaio/blogging-platform-api.git"
  },
  "author": "@barbosacaio",
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/app.ts",
    "migrate": "ts-node scripts/migrate.ts",
    "start": "node dist/app.js",
    "lint": "eslint src",
    "prettier": "prettier --write src"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0"
  }
}
